# =============================================================
# CarbonXchange Backend - Environment Configuration
# Copy this file to .env and fill in values before running
# =============================================================

# --- Flask Application ---
FLASK_ENV=development
SECRET_KEY=change-this-to-a-strong-random-secret-key-32chars
JWT_SECRET_KEY=change-this-to-a-different-strong-secret-key-32chars
PORT=5000

# --- Database ---
DATABASE_URL=postgresql://carbonxchange:carbonxchange_password@localhost:5432/carbonxchange
# For SQLite in development (no PostgreSQL needed):
# DATABASE_URL=sqlite:///./database/dev.db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=carbonxchange_redis_password
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# --- Celery (Background Tasks) ---
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FILE=logs/carbonxchange.log
AUDIT_LOG_FILE=logs/audit.log

# --- File Uploads ---
UPLOAD_FOLDER=uploads

# --- Docker Compose Overrides ---
POSTGRES_PASSWORD=carbonxchange_password
BACKEND_PORT=5000
HTTP_PORT=80

# --- Blockchain (optional) ---
FEATURE_BLOCKCHAIN_INTEGRATION=false
WEB3_PROVIDER_URL=https://polygon-mainnet.infura.io/v3/your-project-id
WEB3_PRIVATE_KEY=
WEB3_CHAIN_ID=137
CARBON_TOKEN_CONTRACT_ADDRESS=
MARKETPLACE_CONTRACT_ADDRESS=
REGISTRY_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=

# --- Email (optional) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@carbonxchange.com
SENDGRID_API_KEY=

# --- SMS / Twilio (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Error Tracking (optional) ---
SENTRY_DSN=

# --- Feature Flags ---
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_AUTOMATED_COMPLIANCE=true
FEATURE_REAL_TIME_NOTIFICATIONS=true
